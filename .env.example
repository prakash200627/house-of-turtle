# PostgreSQL Database Connection URL (Prisma)
DATABASE_URL="postgresql://username:password@localhost:5432/house_of_turtles?schema=public"

# Auth.js / NextAuth Configuration
# Run `npx auth secret` or `openssl rand -base64 33` to generate AUTH_SECRET
AUTH_SECRET="your-32-character-secret-key"
AUTH_URL="http://localhost:3000"

# Google OAuth Credentials
# Retrieve from Google Developer Console -> Credentials -> OAuth 2.0 Client IDs
GOOGLE_CLIENT_ID="your-google-client-id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="your-google-client-secret"
